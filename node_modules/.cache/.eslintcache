am with open eyes to make it possible. <br/> \"Uncharted 3\"\r\n          </p>\r\n        </div>\r\n      </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Footer;\r\n","/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/Header/Header.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/Hero/Hero.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/About/RouteComponents/Experience.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/About/RouteComponents/Internships.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/About/RouteComponents/Graduation.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/About/RouteComponents/Intro.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/Skill/Skill.js",[],[],"/home/myavuz/Desktop/NEwPortfolio/AbyssWatcher-17.github.io/src/components/Contact/Contact.js",["184","185","186"],[],"import React from 'react';\r\n\r\nimport { FontAwesomeIcon } from '@fortawesome/react-fontawesome';\r\nimport { faLocationDot, faPhone, faEnvelope, faSquareCheck } from '@fortawesome/free-solid-svg-icons'\r\nimport {\r\n    faLinkedin,\r\n    faGithub,\r\n    faYoutube,\r\n    faInstagram,\r\n    faTwitter,\r\n} from '@fortawesome/free-brands-svg-icons';\r\n\r\nimport '../../styles/Contact/Contact.scss';\r\nconst Contact = () => {\r\n\r\n    return (\r\n        <>\r\n            <div className=\"contact\" id='contact'>\r\n                <div className=\"contact__header\">\r\n                    <h1>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"0\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            C\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"200\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            O\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"400\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            N\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"600\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            T\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"800\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            A\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"1000\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            C\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"1200\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            T\r\n                        </span>\r\n                        <span\r\n                            data-aos=\"fade-down\"\r\n                            data-aos-delay=\"1400\"\r\n                            data-aos-offset=\"200\"\r\n                        >\r\n                            .\r\n                        </span>\r\n                    </h1>\r\n                </div>\r\n                <div className=\"contact__container\">\r\n                    <div className=\"contact__info\" data-aos=\"fade-up\">\r\n                        <h3 className=\"contact__info-title\">Let's Connect</h3>\r\n                        <div className=\"contact__info-details\">\r\n                            <ul>\r\n                                <li> <FontAwesomeIcon icon={faLocationDot} size=\"2x\" /><p><span>Address:&nbsp;&nbsp;</span>Istanbul,Turkey</p></li>\r\n                                <li> <FontAwesomeIcon icon={faEnvelope} size=\"2x\" /><p><span>Email:&nbsp;&nbsp;</span>    <span\r\n      style={{ color: \"white\", textDecoration: \"underline\", cursor: \"pointer\" }}\r\n      onClick={() => window.open(\"mailto:yavuzgokmene@hotmail.com\")}\r\n    >\r\n      yavuzgokmene@hotmail.com\r\n    </span></p></li>\r\n                            </ul>\r\n                        </div>\r\n                        <div className=\"contact__social\">\r\n                            <p className=\"contact__linkedin\">\r\n                                <a href=\"https://www.linkedin.com/in/myavuzgokmen/\" rel=\"noopener noreferrer\" target=\"_blank\"><FontAwesomeIcon icon={faLinkedin} size=\"2x\" /></a>\r\n                            </p>\r\n\r\n                            <p className='contact__github'>\r\n                                <a href=\"https://github.com/AbyssWatcher-17\" rel=\"noopener noreferrer\" target=\"_blank\"><FontAwesomeIcon icon={faGithub} size=\"2x\" /></a>\r\n                            </p>\r\n                            <p className='contact__instagram'>\r\n                                <a href=\"https://www.instagram.com/yavuz.gokmen17/\" rel=\"noopener noreferrer\" target=\"_blank\"><FontAwesomeIcon icon={faInstagram} size=\"2x\" /></a>\r\n                            </p>\r\n                            <p className='contact__twitter'>\r\n                       